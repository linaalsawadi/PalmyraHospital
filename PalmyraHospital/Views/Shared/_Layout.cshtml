<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Universal Hospitals</title>

    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/dist/css/adminlte.min.css" />

    @RenderSection("Styles", required: false)
</head>

<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">

        <!-- ================= NAVBAR ================= -->
        <nav class="main-header navbar navbar-expand navbar-dark elevation-2"
             style="background-color:#0b3d91;">

            <!-- Left -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" role="button">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>

                <li class="nav-item d-none d-sm-inline-block">
                    <span class="nav-link font-weight-bold">
                        <i class="fas fa-hospital-symbol"></i>
                        Universal Hospital Management System
                    </span>
                </li>
            </ul>

            <!-- Right -->
            <ul class="navbar-nav ml-auto">

                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           data-toggle="dropdown"
                           href="#">
                            <i class="fas fa-user-circle"></i>
                            @User.Identity.Name
                        </a>

                        <div class="dropdown-menu dropdown-menu-right">

                            <span class="dropdown-item-text text-muted small">
                                Role:
                                @(User.IsInRole("Admin") ? "Administrator" :
                                    User.IsInRole("Doctor") ? "Doctor" :
                                    "User")
                            </span>

                            <div class="dropdown-divider"></div>

                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post">
                                <button type="submit"
                                        class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt"></i>
                                    Logout
                                </button>
                            </form>

                        </div>
                    </li>
                }

            </ul>
        </nav>

        <!-- ================= SIDEBAR ================= -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">

            <!-- Logo -->
            <a asp-controller="Home"
               asp-action="Index"
               class="brand-link text-center">
                <span class="brand-text font-weight-light">
                    <i class="fas fa-hospital-alt"></i>
                    Universal Hospitals
                </span>
            </a>

            <div class="sidebar">

                <nav class="mt-3">
                    <ul class="nav nav-pills nav-sidebar flex-column"
                        data-widget="treeview">

                        <!-- Dashboard -->
                        <li class="nav-item">
                            <a asp-area="Admin"
                               asp-controller="Admin"
                               asp-action="Index"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString()=="Admin" ? "active" : "")">

                                <i class="nav-icon fas fa-chart-line"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        <!-- Privacy -->
                        <li class="nav-item">
                            <a asp-controller="Home"
                               asp-action="Privacy"
                               class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString()=="Privacy"?"active":"")">
                                <i class="nav-icon fas fa-user-shield"></i>
                                <p>Privacy</p>
                            </a>
                        </li>

                        <!-- Admin -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item has-treeview">
                                <a href="#" class="nav-link">
                                    <i class="nav-icon fas fa-user-shield"></i>
                                    <p>
                                        Admin Panel
                                        <i class="right fas fa-angle-left"></i>
                                    </p>
                                </a>

                                <ul class="nav nav-treeview">

                                    <!-- Dashboard -->
                                    <li class="nav-item">
                                        <a asp-area="Admin"
                                           asp-controller="Admin"
                                           asp-action="Index"
                                           class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">

                                            <i class="nav-icon fas fa-chart-line"></i>
                                            <p>Dashboard</p>
                                        </a>
                                    </li>

                                    <!-- Departments -->
                                    <li class="nav-item">
                                        <a asp-area="Admin"
                                           asp-controller="Department"
                                           asp-action="Index"
                                           class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Department" ? "active" : "")">

                                            <i class="nav-icon fas fa-hospital"></i>
                                            <p>Departments</p>
                                        </a>
                                    </li>

                                    <!-- Specializations -->
                                    <li class="nav-item">
                                        <a asp-area="Admin"
                                           asp-controller="Specialization"
                                           asp-action="Index"
                                           class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Specialization" ? "active" : "")">

                                            <i class="nav-icon fas fa-stethoscope"></i>
                                            <p>Specializations</p>
                                        </a>
                                    </li>

                                    <!-- Doctors -->
                                    <li class="nav-item">
                                        <a asp-area="Admin"
                                           asp-controller="Doctor"
                                           asp-action="Index"
                                           class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Doctor" ? "active" : "")">

                                            <i class="nav-icon fas fa-user-md"></i>
                                            <p>Doctors</p>
                                        </a>
                                    </li>

                                    <!-- Patients -->
                                    <li class="nav-item">
                                        <a asp-area="Admin"
                                           asp-controller="Patient"
                                           asp-action="Index"
                                           class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Patient" ? "active" : "")">

                                            <i class="nav-icon fas fa-users"></i>
                                            <p>Patients</p>
                                        </a>
                                    </li>

                                    <!-- Appointments -->
                                    <li class="nav-item">
                                        <a asp-area="Admin"
                                           asp-controller="Appointment"
                                           asp-action="Index"
                                           class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Appointment" ? "active" : "")">

                                            <i class="nav-icon fas fa-calendar-alt"></i>
                                            <p>Appointments</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                        }

                        <!-- Doctor -->
                        @if (User.IsInRole("Doctor"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Home"
                                   asp-action="User"
                                   class="nav-link">
                                    <i class="nav-icon fas fa-user-md"></i>
                                    <p>Patients</p>
                                </a>
                            </li>
                        }

                    </ul>
                </nav>
            </div>
        </aside>

        <!-- ================= CONTENT ================= -->
        <div class="content-wrapper">
            <section class="content pt-3">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <!-- ================= FOOTER ================= -->
        <footer class="main-footer text-center">
            <strong> 2026 Palmyra Hospitals.</strong>
            All rights reserved.
        </footer>

    </div>

    <script src="~/plugins/jquery/jquery.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/dist/js/adminlte.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
