@model IEnumerable<PalmyraHospital.Domain.Entities.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h4 class="fw-semibold mb-1">Appointments</h4>
            <small class="text-muted">Manage hospital appointments</small>
        </div>

        <a asp-action="CreateAppointment"
           class="btn btn-primary btn-sm px-4">

            <i class="fas fa-plus me-2"></i>
            New Appointment

        </a>

    </div>


    <!-- Table -->
    <div class="card border-0 shadow-sm">

        <div class="card-body p-0">

            @if (!Model.Any())
            {
                <div class="text-center py-5">

                    <p class="text-muted mb-1">
                        No appointments found
                    </p>

                    <small class="text-muted">
                        Create the first appointment to begin
                    </small>

                </div>
            }
            else
            {
                <table class="table table-hover mb-0">

                    <thead class="table-light">

                        <tr>
                            <th>Date</th>
                            <th>Doctor</th>
                            <th>Patient</th>
                            <th>Status</th>
                            <th width="120">Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @item.AppointmentDate.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    Dr. @item.Doctor.FirstName @item.Doctor.LastName
                                </td>

                                <td>
                                    @item.Patient.FirstName @item.Patient.LastName
                                </td>

                                <td>
                                    <span class="badge bg-light text-dark border">

                                        @item.Status

                                    </span>
                                </td>

                                <td>

                                    <a asp-action="EditAppointment"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-light border">

                                        Edit

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }

        </div>

    </div>

</div>
