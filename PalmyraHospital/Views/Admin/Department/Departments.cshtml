@using PalmyraHospital.Domain.Entities
@model IEnumerable<Department>

<section class="content">

    <div class="container-fluid">


        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h4 class="mb-1 font-weight-normal">
                    Departments
                </h4>

                <small class="text-muted">
                    Hospital organizational structure
                </small>

            </div>

            <a asp-area="Admin"
               asp-controller="Department"
               asp-action="Create"
               class="btn btn-primary">
                <i class="fas fa-user-md"></i>Add Department
            </a>

        </div>


        <!-- Table Card -->
        <div class="card border">

            <div class="card-body p-0">


                @if (!Model.Any())
                {
                    <div class="text-center py-5">

                        <div class="mb-3">
                            <i class="fas fa-building text-muted" style="font-size:32px;"></i>
                        </div>

                        <p class="text-muted mb-3">
                            No departments available
                        </p>

                        <a href="#" class="btn btn-light border btn-sm">
                            Create department
                        </a>

                    </div>
                }
                else
                {

                    <table class="table mb-0">

                        <thead class="border-bottom">

                            <tr class="text-muted">

                                <th class="font-weight-normal">
                                    Name
                                </th>

                                <th class="font-weight-normal">
                                    Description
                                </th>

                                <th style="width:120px;"></th>

                            </tr>

                        </thead>


                        <tbody>

                            @foreach (var item in Model)
                            {

                                <tr>

                                    <td>
                                        @item.Name
                                    </td>

                                    <td class="text-muted">
                                        @item.Description
                                    </td>

                                    <td class="text-right">

                                        <a href="#" class="text-muted mr-3">
                                            Edit
                                        </a>

                                        <a href="#" class="text-danger">
                                            Delete
                                        </a>

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                }


            </div>

        </div>


    </div>

</section>
