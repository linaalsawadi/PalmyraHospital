@model IEnumerable<Doctor>

<section class="content">

    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h4 class="mb-1 font-weight-normal">Doctors</h4>
                <small class="text-muted">Hospital medical staff directory</small>
            </div>

            <a asp-area="Admin"
               asp-controller="Doctor"
               asp-action="Create"
               class="btn btn-primary">
                <i class="fas fa-user-md"></i> Add Doctor
            </a>




        </div>


        <!-- Card -->
        <div class="card border">

            <div class="card-body p-0">

                @if (!Model.Any())
                {
                    <div class="text-center py-5">

                        <i class="fas fa-user-md text-muted mb-2" style="font-size:28px;"></i>

                        <p class="text-muted mb-2">
                            No doctors available
                        </p>

                        <a href="#" class="btn btn-light border btn-sm">
                            Create doctor
                        </a>

                    </div>
                }
                else
                {

                    <table class="table mb-0">

                        <thead class="border-bottom text-muted">

                            <tr>

                                <th class="font-weight-normal">Name</th>

                                <th class="font-weight-normal">Specialization</th>

                                <th class="font-weight-normal">Phone</th>

                                <th style="width:120px;"></th>

                            </tr>

                        </thead>


                        <tbody>

                            @foreach (var doctor in Model)
                            {

                                <tr>

                                    <td>
                                        Dr. @doctor.FirstName @doctor.LastName
                                    </td>

                                    <td class="text-muted">
                                        @doctor.Specialization?.Name
                                    </td>

                                    <td class="text-muted">
                                        @doctor.PhoneNumber
                                    </td>

                                    <td class="text-right">

                                        <a href="#" class="text-muted mr-3">
                                            Edit
                                        </a>

                                        <a href="#" class="text-danger">
                                            Delete
                                        </a>

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                }

            </div>

        </div>

    </div>

</section>
