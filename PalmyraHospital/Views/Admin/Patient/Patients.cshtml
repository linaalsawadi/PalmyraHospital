@using PalmyraHospital.Domain.Entities
@model IEnumerable<Patient>

<section class="content">

    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h4 class="mb-1 font-weight-normal">Patients</h4>
                <small class="text-muted">Registered patient records</small>
            </div>

            <a href="#" class="btn btn-outline-primary btn-sm">
                Add Patient
            </a>

        </div>


        <!-- Card -->
        <div class="card border">

            <div class="card-body p-0">

                @if (!Model.Any())
                {
                    <div class="text-center py-5">

                        <i class="fas fa-user text-muted mb-2" style="font-size:28px;"></i>

                        <p class="text-muted mb-2">
                            No patients registered
                        </p>

                        <a href="#" class="btn btn-light border btn-sm">
                            Register patient
                        </a>

                    </div>
                }
                else
                {

                    <table class="table mb-0">

                        <thead class="border-bottom text-muted">

                            <tr>

                                <th class="font-weight-normal">Name</th>

                                <th class="font-weight-normal">Phone</th>

                                <th class="font-weight-normal">Date of Birth</th>

                                <th style="width:120px;"></th>

                            </tr>

                        </thead>


                        <tbody>

                            @foreach (var patient in Model)
                            {

                                <tr>

                                    <td>
                                        @patient.FirstName @patient.LastName
                                    </td>

                                    <td class="text-muted">
                                        @patient.PhoneNumber
                                    </td>

                                    <td class="text-muted">
                                        @patient.DateOfBirth.ToString("yyyy-MM-dd")
                                    </td>

                                    <td class="text-right">

                                        <a href="#" class="text-muted mr-3">
                                            Edit
                                        </a>

                                        <a href="#" class="text-danger">
                                            Delete
                                        </a>

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                }

            </div>

        </div>

    </div>

</section>
