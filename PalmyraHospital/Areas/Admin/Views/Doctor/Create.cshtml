@model PalmyraHospital.Web.ViewModels.Admin.CreateDoctorViewModel

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1 font-weight-normal">Create Doctor</h4>
            <small class="text-muted">Add a new doctor account and profile</small>
        </div>
        <a asp-action="Doctors" class="btn btn-light border btn-sm">Back</a>
    </div>

    <div class="card border">
        <div class="card-body">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="text-danger mb-3" asp-validation-summary="All"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Email</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Password</label>
                        <input asp-for="Password" type="password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">First Name</label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Last Name</label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">License Number</label>
                        <input asp-for="LicenseNumber" class="form-control" />
                        <span asp-validation-for="LicenseNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Department</label>
                        <select asp-for="DepartmentId" class="form-control">
                            <option value="">Select Department</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Specialization</label>
                        <select asp-for="SpecializationId" class="form-control">
                            <option value="">Select Specialization</option>
                            @foreach (var s in Model.Specializations)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                        <span asp-validation-for="SpecializationId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Years of Experience</label>
                        <input asp-for="YearsOfExperience" class="form-control" />
                        <span asp-validation-for="YearsOfExperience" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Consultation Fee</label>
                        <input asp-for="ConsultationFee" class="form-control" />
                        <span asp-validation-for="ConsultationFee" class="text-danger small"></span>
                    </div>

                </div>

                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-outline-primary btn-sm">
                        Create Doctor
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>
