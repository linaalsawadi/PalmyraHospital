@using PalmyraHospital.Application.DTOs.Admin
@model IEnumerable<DoctorDto>

<section class="content">

    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h4 class="mb-1 font-weight-normal">Doctors</h4>
                <small class="text-muted">Hospital medical staff directory</small>
            </div>

            <a asp-area="Admin"
               asp-controller="Doctor"
               asp-action="Create"
               class="btn btn-primary">
                <i class="fas fa-user-md"></i> Add Doctor
            </a>

        </div>


        <!-- Card -->
        <div class="card border shadow-sm">

            <div class="card-body p-0">

                @if (!Model.Any())
                {
                    <div class="text-center py-5">

                        <i class="fas fa-user-md text-muted mb-2" style="font-size:28px;"></i>

                        <p class="text-muted mb-2">
                            No doctors available
                        </p>

                        <a asp-action="Create"
                           class="btn btn-outline-primary btn-sm">
                            Create doctor
                        </a>

                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">

                        <thead class="table-light border-bottom text-muted">

                            <tr>
                                <th>Name</th>
                                <th>Department</th>
                                <th>Specialization</th>
                                <th>Phone</th>
                                <th>Experience</th>
                                <th>Fee</th>
                                <th style="width:150px;"></th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var doctor in Model)
                            {
                                <tr>

                                    <td>
                                        <strong>Dr. @doctor.FullName</strong>
                                    </td>

                                    <td class="text-muted">
                                        @doctor.Department
                                    </td>

                                    <td class="text-muted">
                                        @doctor.Specialization
                                    </td>

                                    <td class="text-muted">
                                        @doctor.Phone
                                    </td>

                                    <td class="text-muted">
                                        @doctor.YearsOfExperience yrs
                                    </td>

                                    <td class="text-muted">
                                        @doctor.ConsultationFee.ToString("C")
                                    </td>

                                    <td class="text-end">

                                        <a asp-area="Admin"
                                           asp-controller="Doctor"
                                           asp-action="Edit"
                                           asp-route-id="@doctor.Id"
                                           class="btn btn-sm btn-light border me-2">
                                            Edit
                                        </a>

                                        <form asp-area="Admin"
                                              asp-controller="Doctor"
                                              asp-action="Delete"
                                              method="post"
                                              class="d-inline">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="id" value="@doctor.Id" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Delete this doctor?');">
                                                Delete
                                            </button>

                                        </form>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                }

            </div>

        </div>

    </div>

</section>