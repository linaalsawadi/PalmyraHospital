@using PalmyraHospital.Application.DTOs.Admin
@model IEnumerable<DepartmentDto>

<section class="content">

    <div class="container-fluid">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h4 class="mb-1 font-weight-normal">Departments</h4>
                <small class="text-muted">Hospital organizational structure</small>
            </div>

            <a asp-area="Admin"
               asp-controller="Department"
               asp-action="Create"
               class="btn btn-primary">
                <i class="fas fa-building me-2"></i>
                Add Department
            </a>
        </div>

        <div class="card border shadow-sm">
            <div class="card-body p-0">

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-building text-muted mb-3" style="font-size:32px;"></i>

                        <p class="text-muted mb-3">
                            No departments available
                        </p>

                        <a asp-action="Create" class="btn btn-primary btn-sm">
                            Create department
                        </a>
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">

                        <thead class="table-light border-bottom">
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th style="width:150px;"></th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td><strong>@item.Name</strong></td>

                                    <td class="text-muted">
                                        @(string.IsNullOrEmpty(item.Description) ? "-" : item.Description)
                                    </td>

                                    <td class="text-end">

                                        <a asp-area="Admin"
                                           asp-controller="Department" 
                                           asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-light border me-2">
                                            Edit
                                        </a>

                                        <form asp-area="Admin"
                                              asp-controller="Department" 
                                              asp-action="Delete"
                                              method="post"
                                              class="d-inline">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="id" value="@item.Id" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Delete this department?');">
                                                Delete
                                            </button>

                                        </form>

                                    </td>

                                </tr>
                            }

                        </tbody>
                    </table>
                }

            </div>
        </div>

    </div>
</section>