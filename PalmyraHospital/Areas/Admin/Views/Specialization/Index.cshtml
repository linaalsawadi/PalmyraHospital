@model IEnumerable<PalmyraHospital.Application.DTOs.Admin.SpecializationDto>

<section class="content">
    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="mb-1">Specializations</h4>
                <small class="text-muted">Manage hospital specializations</small>
            </div>

            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add Specialization
            </a>
        </div>

        <!-- Table -->
        <div class="card">
            <div class="card-body p-0">

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <p class="text-muted">No specializations found</p>
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Department</th>
                                <th style="width:150px;"></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var s in Model)
                            {
                                <tr>
                                    <td>@s.Name</td>
                                    <td class="text-muted">@s.DepartmentName</td>

                                    <td class="text-end">
                                        <a asp-action="Edit"
                                           asp-route-id="@s.Id"
                                           class="btn btn-sm btn-light border me-2">
                                            Edit
                                        </a>

                                        <form asp-action="Delete"
                                              method="post"
                                              class="d-inline">
                                            <input type="hidden" name="id" value="@s.Id" />
                                            <button class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Delete?')">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                }

            </div>
        </div>

    </div>
</section>