@model CreatePatientViewModel

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1 font-weight-normal">Create Patient</h4>
            <small class="text-muted">Register a new patient record</small>
        </div>

        <a asp-action="Index" class="btn btn-light border btn-sm">
            Back
        </a>
    </div>

    <!-- Card -->
    <div class="card border">
        <div class="card-body">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row">

                    <!-- First Name -->
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">First Name</label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <!-- Last Name -->
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Last Name</label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>

                    <!-- Date of Birth -->
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>

                    <!-- Gender -->
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Gender</label>
                        <select asp-for="Gender" class="form-control">
                            <option value="">Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger small"></span>
                    </div>

                    <!-- National ID -->
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">National ID</label>
                        <input asp-for="NationalId" class="form-control" />
                        <span asp-validation-for="NationalId" class="text-danger small"></span>
                    </div>

                    <!-- Phone -->
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <!-- Address -->
                    <div class="col-md-12 mb-3">
                        <label class="text-muted small">Address</label>
                        <input asp-for="Address" class="form-control" />
                    </div>

                </div>

                <!-- Submit -->
                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-outline-primary btn-sm">
                        Create Patient
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>