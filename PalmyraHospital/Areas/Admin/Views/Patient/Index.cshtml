@using PalmyraHospital.Application.DTOs.Admin
@model IEnumerable<PatientDto>

<section class="content">

    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h4 class="mb-1 font-weight-normal">Patients</h4>
                <small class="text-muted">Registered patient records</small>
            </div>

            <a asp-action="Create" class="btn btn-outline-primary btn-sm">
                Add Patient
            </a>

        </div>


        <!-- Card -->
        <div class="card border">

            <div class="card-body p-0">

                @if (!Model.Any())
                {
                    <div class="text-center py-5">

                        <i class="fas fa-user text-muted mb-2" style="font-size:28px;"></i>

                        <p class="text-muted mb-2">
                            No patients registered
                        </p>

                        <a asp-action="Create" class="btn btn-light border btn-sm">
                            Register patient
                        </a>

                    </div>
                }
                else
                {

                    <table class="table mb-0">

                        <thead class="border-bottom text-muted">

                            <tr>

                                <th class="font-weight-normal">Name</th>

                                <th class="font-weight-normal">Phone</th>

                                <th class="font-weight-normal">Date of Birth</th>

                                <th style="width:120px;"></th>

                            </tr>

                        </thead>


                        <tbody>

                            @foreach (var patient in Model)
                            {

                                <tr>

                                    <td>
                                        @patient.FullName
                                    </td>

                                    <td class="text-muted">
                                        @patient.Phone
                                    </td>

                                    <td class="text-muted">
                                        @patient.DateOfBirth.ToString("yyyy-MM-dd")
                                    </td>

                                    <td class="text-right">

                                        <a asp-action="Edit"
                                           asp-route-id="@patient.Id"
                                           class="text-muted me-3">
                                            Edit
                                        </a>
                                        <form asp-action="Delete"
                                              method="post"
                                              class="d-inline">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="id"
                                                   value="@patient.Id" />

                                            <button type="submit"
                                                    class="text-danger border-0 bg-transparent"
                                                    onclick="return confirm('Are you sure you want to delete this patient?')">
                                                Delete
                                            </button>

                                        </form>

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                }

            </div>

        </div>

    </div>

</section>
