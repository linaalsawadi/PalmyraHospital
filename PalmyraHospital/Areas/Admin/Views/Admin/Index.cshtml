@model PalmyraHospital.Application.DTOs.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row">

        <!-- Total Doctors -->
        <div class="col-lg-3 col-6">
            <div class="small-box bg-primary">
                <div class="inner">
                    <h3>@Model.TotalDoctors</h3>
                    <p>Active Doctors</p>
                </div>
                <div class="icon">
                    <i class="fas fa-user-md"></i>
                </div>
            </div>
        </div>

        <!-- Archived Doctors -->
        <div class="col-lg-3 col-6">
            <div class="small-box bg-secondary">
                <div class="inner">
                    <h3>@Model.ArchivedDoctors</h3>
                    <p>Archived Doctors</p>
                </div>
                <div class="icon">
                    <i class="fas fa-user-times"></i>
                </div>
            </div>
        </div>

        <!-- Total Patients -->
        <div class="col-lg-3 col-6">
            <div class="small-box bg-success">
                <div class="inner">
                    <h3>@Model.TotalPatients</h3>
                    <p>Total Patients</p>
                </div>
                <div class="icon">
                    <i class="fas fa-users"></i>
                </div>
            </div>
        </div>

        <!-- Total Departments -->
        <div class="col-lg-3 col-6">
            <div class="small-box bg-info">
                <div class="inner">
                    <h3>@Model.TotalDepartments</h3>
                    <p>Departments</p>
                </div>
                <div class="icon">
                    <i class="fas fa-hospital"></i>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-3">

        <!-- Today's Appointments -->
        <div class="col-lg-4 col-6">
            <div class="small-box bg-warning">
                <div class="inner">
                    <h3>@Model.TodayAppointments</h3>
                    <p>Today's Appointments</p>
                </div>
                <div class="icon">
                    <i class="fas fa-calendar-day"></i>
                </div>
            </div>
        </div>

    </div>
</div>
